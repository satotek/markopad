{
  "name": "@markopad/web",
  "version": "0.0.1",
  "description": "Web application shell for MarkoPad (React Native Web / Expo)",
  "private": true,
  "main": "src/index.tsx",
  "scripts": {
    "dev": "expo start --web",
    "build": "expo export --platform web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@markopad/core": "workspace:*",
    "@markopad/preview": "workspace:*",
    "@markopad/ui": "workspace:*",
    "expo": "~54.0.0",
    "expo-modules-core": "^3.0.26",
    "expo-status-bar": "~3.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "~0.81.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
