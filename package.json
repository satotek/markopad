{
  "name": "markopad",
  "version": "0.0.1",
  "description": "Cross-platform Markdown note-taking app with real-time preview and Mermaid diagram support",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @markopad/web dev",
    "build": "pnpm --filter @markopad/web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
